# ============================================
# Environment-Specific Configuration
# ============================================
# Copy this file to .env.dev or .env.prod and adjust values accordingly

# Environment (development|production)
NODE_ENV=production

# ============================================
# Database Configuration (PostgreSQL + PostGIS)
# ============================================
# CHANGE per environment (e.g., myapp_dev, myapp_prod)
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mySecurePassword123
POSTGRES_DB=myapp_db
POSTGRES_PORT=5432

# PostGIS is enabled by default via init-scripts/01-init-postgis.sql
# Image: postgis/postgis:16-3.4-alpine
# Connect via local pgAdmin: localhost:5432

# ============================================
# NestJS Backend Configuration
# ============================================
NESTJS_PORT=3001
# CHANGE in production - use a strong random secret
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# CHANGE per environment (dev: http://localhost:3000, prod: https://yourdomain.com)
CORS_ORIGIN=http://localhost:3000

# ============================================
# Next.js Frontend Configuration
# ============================================
# Note: When using Nginx, frontend is not exposed directly
# Access via Nginx on port 80 instead
# CHANGE per environment (dev: http://localhost/api, prod: https://yourdomain.com/api)
NEXT_PUBLIC_API_URL=http://localhost/api

# ============================================
# Nginx Configuration
# ============================================
NGINX_PORT=80
# CHANGE per environment (dev: localhost, prod: yourdomain.com)
NGINX_SERVER_NAME=localhost

# ============================================
# Optional: Additional configurations
# ============================================
# REDIS_URL=redis://redis:6379
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
