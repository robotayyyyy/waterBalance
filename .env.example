NODE_ENV=production

# Postgres
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=postgres

# Database connection (local dev: localhost, Docker: postgres)
DATABASE_HOST=
DATABASE_PORT=
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=postgres

# Backend
JWT_SECRET=change-this-secret-in-production
CORS_ORIGIN=*
LOG_LEVEL=info

# Frontend — baked at build time, requires rebuild to change
# local dev: http://localhost:3001 | Docker: /api
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_SHOW_ID=false
NEXT_PUBLIC_ENABLE_SUBBASIN_L2=false

# Protomaps — get free key at protomaps.com
NEXT_PUBLIC_PROTOMAPS_KEY=

# Maptiler — optional, enables terrain hillshading, get free key at maptiler.com
NEXT_PUBLIC_MAPTILER_KEY=

# PMTiles file URLs — local dev uses Next.js public dir, replace with hosted URLs in production
NEXT_PUBLIC_PMTILES_ADM1_URL=/thaimap/tha-province.pmtiles
NEXT_PUBLIC_PMTILES_ADM2_URL=/thaimap/tha-amphoe.pmtiles
NEXT_PUBLIC_PMTILES_ADM3_URL=/thaimap/tha-tambon.pmtiles

# Nginx
NGINX_SERVER_NAME=localhost
