# WaterF Environment Configuration
# Copy this file to .env and customize for your environment

# === Application ===
NODE_ENV=production

# === Database (PostgreSQL + PostGIS) ===
# For local dev: use localhost
# For Docker: use postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=postgres

# === Backend API ===
PORT=3001
JWT_SECRET=change-this-secret-in-production
CORS_ORIGIN=*

# === Logging ===
LOG_LEVEL=info

# === Frontend (Build-Time Configuration) ===
# IMPORTANT: NEXT_PUBLIC_* variables are baked into the JavaScript bundle at BUILD time
# They CANNOT be changed at runtime without rebuilding
#
# For local dev (make dev): Set to http://localhost:3001 for direct backend access
# For Docker (make build): Set to /api (proxied through nginx)
# Leave empty to use default fallback: /api
#
# Examples:
#   NEXT_PUBLIC_API_URL=http://localhost:3001  # Local development
#   NEXT_PUBLIC_API_URL=/api                   # Docker production (default)
#   NEXT_PUBLIC_API_URL=https://api.example.com # Custom production API
NEXT_PUBLIC_API_URL=
